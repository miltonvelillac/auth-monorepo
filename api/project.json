{
  "name": "api",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "api/src",
  "projectType": "application",
  "tags": ["scope:auth", "type:api"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm --workspace api run build"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm --workspace api run dev"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm --workspace api run test"
      }
    }
  }
}
